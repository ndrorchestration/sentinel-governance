# Copy this file to .env and replace the placeholder values.

# GitHub App credentials
GITHUB_APP_ID=1234567
GITHUB_WEBHOOK_SECRET=replace_with_a_long_random_secret
GITHUB_APP_PRIVATE_KEY_PATH=./private-key.pem

# Operator server
PORT=3000
SENTINEL_MODE=observe

# Orchestrator integration
ORCHESTRATOR_URL=http://localhost:8000/sentinel/repair
ORCHESTRATOR_KEY=replace_with_shared_orchestrator_token
